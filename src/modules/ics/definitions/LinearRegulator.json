{
  "module": "Linear Regulator",
  "logicModule": "LinearRegulator",
  "gridX": 3,
  "gridY": 2,
  "background": "#1C1917",
  "css": "border-radius: 6px; border: 2px solid #78716C;",
  "category": "ics",
  "description": "Adjustable linear regulator — output set by ADJ divider (R1: OUT→ADJ, R2: ADJ→GND)",
  "grid": [
    {
      "x": 0,
      "y": 0,
      "type": "DRIVER_PWR",
      "pin": "VIN",
      "isConnectable": true,
      "isPowerable": true,
      "isGroundable": false,
      "css": "background:#DC2626;color:white;font-size:10px;font-weight:bold;display:flex;align-items:center;justify-content:center;border-radius:6px 0 0 0;"
    },
    {
      "x": 1,
      "y": 0,
      "type": "BODY",
      "pin": "",
      "isConnectable": false,
      "css": "background:#44403C;color:#F5F5F4;font-size:9px;font-weight:bold;display:flex;align-items:center;justify-content:center;"
    },
    {
      "x": 2,
      "y": 0,
      "type": "DRIVER_OUT",
      "pin": "VOUT",
      "isConnectable": true,
      "isPowerable": true,
      "isGroundable": false,
      "css": "background:#059669;color:white;font-size:10px;font-weight:bold;display:flex;align-items:center;justify-content:center;border-radius:0 6px 0 0;"
    },
    {
      "x": 0,
      "y": 1,
      "type": "GND",
      "pin": "GND",
      "isConnectable": true,
      "isPowerable": false,
      "isGroundable": true,
      "css": "background:#4C1D95;color:white;font-size:10px;font-weight:bold;display:flex;align-items:center;justify-content:center;border-radius:0 0 0 6px;"
    },
    {
      "x": 1,
      "y": 1,
      "type": "INPUT",
      "pin": "ADJ",
      "isConnectable": true,
      "isPowerable": true,
      "isGroundable": true,
      "css": "background:#D97706;color:#111;font-size:10px;font-weight:bold;display:flex;align-items:center;justify-content:center;"
    },
    {
      "x": 2,
      "y": 1,
      "type": "BODY",
      "pin": "",
      "isConnectable": false,
      "css": "background:#1C1917;border-radius:0 0 6px 0;"
    }
  ],
  "properties": {
    "vref": { "default": 1.25, "unit": "V", "description": "Reference voltage at ADJ pin" },
    "dropout": { "default": 2, "unit": "V", "description": "Minimum headroom VIN − VOUT" },
    "maxCurrent": { "default": 1.5, "unit": "A", "description": "Maximum output current" },
    "seriesResistance": { "default": 0.1, "unit": "Ω", "description": "Output source resistance" },
    "quiescentCurrent": { "default": 0.005, "unit": "A", "description": "Quiescent current draw" }
  }
