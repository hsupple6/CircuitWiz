{
  "module": "Brushed Motor Driver",
  "logicModule": "BrushedDriver",
  "gridX": 3,
  "gridY": 3,
  "background": "#1a1a2e",
  "css": "border-radius: 6px; border: 2px solid #6366F1;",
  "category": "drivers",
  "description": "Brushed DC H-bridge — PWM/DIR inputs drive OUT1/OUT2 to a brushed motor",
  "grid": [
