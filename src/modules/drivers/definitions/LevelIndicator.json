    { "x": 1, "y": 0, "type": "BODY", "pin": "LVL", "isConnectable": false, "css": "background:#115E59;color:#99F6E4;font-size:9px;font-weight:bold;display:flex;align-items:center;justify-content:center;" },
    { "x": 2, "y": 0, "type": "GND", "pin": "GND", "isConnectable": true, "isPowerable": false, "isGroundable": true, "css": "background:#4C1D95;color:white;font-size:10px;font-weight:bold;display:flex;align-items:center;justify-content:center;border-radius:0 6px 0 0;" },
    { "x": 0, "y": 1, "type": "DRIVER_CTRL", "pin": "BAT", "isConnectable": true, "isPowerable": true, "isGroundable": false, "css": "background:#0D9488;color:white;font-size:10px;font-weight:bold;display:flex;align-items:center;justify-content:center;border-radius:0 0 0 6px;" },
    { "x": 1, "y": 1, "type": "DUMMY", "pin": "LED1", "isConnectable": true, "isPowerable": false, "isGroundable": false, "css": "background:#134E4A;color:#94A3B8;font-size:9px;font-weight:bold;display:flex;align-items:center;justify-content:center;border:1px dashed #2DD4BF;" },
    { "x": 2, "y": 1, "type": "DUMMY", "pin": "LED4", "isConnectable": true, "isPowerable": false, "isGroundable": false, "css": "background:#134E4A;color:#94A3B8;font-size:9px;font-weight:bold;display:flex;align-items:center;justify-content:center;border:1px dashed #2DD4BF;border-radius:0 0 6px 0;" }
