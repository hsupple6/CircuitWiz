{
  "module": "Bluetooth Module",
  "logicModule": "BluetoothModule",
  "gridX": 3,
  "gridY": 3,
  "background": "#1E1B4B",
  "css": "border-radius: 6px; border: 2px solid #6366F1;",
  "category": "wireless",
  "description": "Generic UART Bluetooth module — VCC/GND/TX/RX/EN plus RF antenna pin",
  "grid": [
    {
      "x": 0,
      "y": 0,
      "type": "DRIVER_PWR",
      "pin": "VCC",
      "isConnectable": true,
      "isPowerable": true,
      "isGroundable": false,
      "css": "background:#DC2626;color:white;font-size:9px;font-weight:bold;display:flex;align-items:center;justify-content:center;border-radius:6px 0 0 0;"
    },
    {
      "x": 1,
      "y": 0,
      "type": "DRIVER_CTRL",
      "pin": "TX",
      "isConnectable": true,
      "isPowerable": true,
      "isGroundable": false,
      "css": "background:#2563EB;color:white;font-size:9px;font-weight:bold;display:flex;align-items:center;justify-content:center;"
    },
    {
      "x": 2,
      "y": 0,
      "type": "GND",
      "pin": "GND",
      "isConnectable": true,
      "isPowerable": false,
      "isGroundable": true,
      "css": "background:#4C1D95;color:white;font-size:9px;font-weight:bold;display:flex;align-items:center;justify-content:center;border-radius:0 6px 0 0;"
    },
    {
      "x": 0,
      "y": 1,
      "type": "DRIVER_CTRL",
      "pin": "RX",
      "isConnectable": true,
      "isPowerable": true,
      "isGroundable": false,
      "css": "background:#2563EB;color:white;font-size:9px;font-weight:bold;display:flex;align-items:center;justify-content:center;"
    },
    {
      "x": 1,
      "y": 1,
      "type": "BODY",
      "pin": "BT",
      "isConnectable": false,
      "isClickable": true,
      "css": "background:#312E81;color:#C7D2FE;font-size:9px;font-weight:bold;display:flex;align-items:center;justify-content:center;"
    },
    {
      "x": 2,
      "y": 1,
      "type": "RF",
      "pin": "ANT",
      "isConnectable": true,
      "isPowerable": true,
      "isGroundable": false,
      "css": "background:#0369A1;color:white;font-size:9px;font-weight:bold;display:flex;align-items:center;justify-content:center;"
    },
    {
      "x": 0,
      "y": 2,
      "type": "DRIVER_CTRL",
      "pin": "EN",
      "isConnectable": true,
      "isPowerable": true,
      "isGroundable": false,
      "css": "background:#4338CA;color:white;font-size:9px;font-weight:bold;display:flex;align-items:center;justify-content:center;border-radius:0 0 0 6px;"
    },
    {
      "x": 1,
      "y": 2,
      "type": "DUMMY",
      "pin": "STATE",
      "isConnectable": true,
      "isPowerable": false,
      "isGroundable": false,
      "css": "background:#1E1B4B;color:#94A3B8;font-size:9px;font-weight:bold;display:flex;align-items:center;justify-content:center;border:1px dashed #6366F1;"
    },
    {
      "x": 2,
      "y": 2,
      "type": "DUMMY",
      "pin": "KEY",
      "isConnectable": true,
      "isPowerable": false,
      "isGroundable": false,
      "css": "background:#1E1B4B;color:#94A3B8;font-size:9px;font-weight:bold;display:flex;align-items:center;justify-content:center;border:1px dashed #6366F1;border-radius:0 0 6px 0;"
    }
  ],
  "properties": {
    "vth": { "default": 1.5, "unit": "V", "description": "Logic input threshold" },
    "idleCurrent": { "default": 0.008, "unit": "A", "description": "Quiescent supply current" }
  }
}
